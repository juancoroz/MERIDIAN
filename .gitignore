/rocket_6dof/third_party/imgui/*.h
/rocket_6dof/third_party/imgui/backends/*.cpp
/rocket_6dof/third_party/imgui/backends/*.h
/rocket_6dof/third_party/implot/*.cpp
/rocket_6dof/third_party/implot/*.h
/rocket_6dof/third_party/stb/*.h
!**/third_party/**/README.md     # but keep the README stubs

