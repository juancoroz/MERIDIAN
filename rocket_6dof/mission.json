// =====================================================================
//  mission.json -- Sample mission config for rocket_6dof
//
//  This file reproduces the hardcoded baseline mission: a 1000 kg
//  single-stage vehicle with 500 kg propellant burning for 25 sec,
//  launched vertically from Cape Canaveral, executing a programmed
//  pitch maneuver from 89 to 70 deg between t=3 and t=15, with
//  cascaded attitude-tracking autopilot through max-q.
//
//  Edit any field to customize the mission.  Missing fields keep
//  whatever default the block's constructor set.  Lines starting
//  with `//` are comments.
// =====================================================================
{
  // ---- Propulsion: single-stage solid motor, 25 sec burn ----
  "propulsion": {
    "mprop":          3,          // 3 = constant thrust via spi * mdot
    "vmass0":         1000.0,     // [kg] total vehicle mass at t=0
    "fmass0":         500.0,      // [kg] propellant mass
    "spi":            300.0,      // [s]  specific impulse
    "fuel_flow_rate": 20.0,       // [kg/s] -> gives 25 s burn
    "moi_roll_0":     10.0,       // [kg m^2] roll-axis MoI, full
    "moi_roll_1":     5.0,        // [kg m^2] roll-axis MoI, empty
    "moi_trans_0":    500.0,      // [kg m^2] transverse MoI, full
    "moi_trans_1":    250.0,      // [kg m^2] transverse MoI, empty
    "xcg_0":          3.0,        // [m]  CG location from nose, full
    "xcg_1":          2.5         // [m]  CG location from nose, empty
  },

  // ---- Aerodynamics: SLV-3 stage data tables ----
  "aerodynamics": {
    "maero":     13,
    "refa":      1.0,
    "refd":      1.0,
    "xcg_ref":   3.0,
    "aero_file": "aero.txt",
    "tag_ca0":   "ca0slv3_vs_mach",
    "tag_caa":   "caaslv3_vs_mach",
    "tag_ca0b":  "ca0bslv3_vs_mach",
    "tag_cn0":   "cn0slv3_vs_mach_alpha",
    "tag_clm0":  "clm0slv3_vs_mach_alpha",
    "tag_clmq":  "clmqslv3_vs_mach"
  },

  // ---- TVC: active gimbal with 15 deg limit ----
  "tvc": {
    "mtvc":    1,
    "gtvc":    1.0,
    "parm":    5.0,         // [m]  gimbal location from nose
    "del_max": 15.0         // [deg]
  },

  // ---- RCS: off during atmospheric flight ----
  "rcs": {
    "mrcs_moment": 0,
    "mrcs_force":  0
  },

  // ---- Control: cascaded attitude-tracking autopilot ----
  "control": {
    "maut":                60,
    "vac_rate_damp":       0.5,
    "vac_max_gain":        1.0,
    "tau_att":             1.0,
    "q_max":               15.0,
    "theta_com_inertial":  89.0,    // initial; Guidance overrides
    "psi_com_inertial":    90.0,
    "delimx":              15.0,
    "drlimx":              15.0,
    "gnmax":               5.0,
    "gymax":               5.0
  },

  // ---- Guidance: time-programmed attitude maneuver (mguide=2) ----
  // Hold theta=89 for 3 sec to clear the pad, then ramp to 70 over 12
  // sec to execute an active gravity-turn tipover.  Heading held at 90
  // (East) throughout.
  "guidance": {
    "mguide":          2,
    "t_att_start":     3.0,
    "t_att_end":       15.0,
    "theta_com_start": 89.0,
    "theta_com_end":   70.0,
    "psi_com_start":   90.0,
    "psi_com_end":     90.0
  },

  // ---- INS: constant biases ----
  "ins": {
    "mins":       1,
    "bias_accel": [0.001, 0.0, 0.0],     // [m/s^2]
    "bias_gyro":  [1.0e-5, 0.0, 0.0]     // [rad/s]
  },

  // ---- GPS: noisy, 1 Hz ----
  "gps": {
    "mgps":       2,
    "gps_step":   1.0,
    "rpos":       5.0,
    "rvel":       0.1,
    "noise_seed": 12345
  },

  // ---- StarTrack: noisy, 1 Hz, requires alt > 100 km ----
  "startrack": {
    "mstar":          2,
    "startrack_step": 1.0,
    "startrack_alt":  100000.0,
    "star_acqtime":   2.0,
    "tilt_noise":     1.0e-4
  },

  // ---- Intercept: terminate at burnout (t=25s) or 100 km ----
  "intercept": {
    "check_alt_max":  true,
    "check_time_max": true,
    "alt_max":        100000.0,
    "t_max":          25.0
  },

  // ---- Launch site: Cape Canaveral, vertical ascent ----
  "launch": {
    "lonx0":   -80.0,        // [deg E]
    "latx0":    28.5,        // [deg N]
    "alt0":     0.0,         // [m]    sea level
    "dvbe0":    0.01,        // [m/s]  tiny init velocity (avoids /0)
    "psivdx0":  90.0,        // [deg]  heading East
    "thtvdx0":  89.0,        // [deg]  flight-path nearly vertical
    "psibdx0":  90.0,        // [deg]  body heading East
    "thtbdx0":  89.0,        // [deg]  body pitched up
    "phibdx0":  0.0,
    "ppx0":     0.0,
    "qqx0":     0.0,
    "rrx0":     0.0
  },

  // ---- Simulation parameters ----
  "sim": {
    "dt":    0.01,           // [s]   integration step
    "t_max": 26.0            // [s]   simulation duration (Intercept can fire earlier)
  }
}
