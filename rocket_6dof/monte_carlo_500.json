// =====================================================================
//  monte_carlo_500.json -- Full dispersion sweep, 500 runs
//
//  Same physical perturbations as monte_carlo.json plus:
//    - gps.noise_seed:        uniform over a large range so INS
//                             position-error floor varies per run
//    - startrack tilt_noise:  lognormal magnitude scatter
//    - ins.bias_gyro[0]:      lognormal multiplicative scatter
//
//  500 runs gives ~5x tighter statistics than the previous 50-run
//  sweep, sufficient to characterize the tails of the body-attitude
//  dispersion.  Run time ~15 s at ~30 ms/run.
// =====================================================================
{
  // ---- Baseline mission (same as monte_carlo.json) ----
  "propulsion": {
    "mprop": 3, "vmass0": 1000.0, "fmass0": 500.0, "spi": 300.0,
    "fuel_flow_rate": 20.0,
    "moi_roll_0":  10.0,  "moi_roll_1":  5.0,
    "moi_trans_0": 500.0, "moi_trans_1": 250.0,
    "xcg_0": 3.0, "xcg_1": 2.5
  },
  "aerodynamics": {
    "maero": 13, "refa": 1.0, "refd": 1.0, "xcg_ref": 3.0,
    "aero_file": "aero.txt",
    "tag_ca0":  "ca0slv3_vs_mach",
    "tag_caa":  "caaslv3_vs_mach",
    "tag_ca0b": "ca0bslv3_vs_mach",
    "tag_cn0":  "cn0slv3_vs_mach_alpha",
    "tag_clm0": "clm0slv3_vs_mach_alpha",
    "tag_clmq": "clmqslv3_vs_mach"
  },
  "tvc": { "mtvc": 1, "gtvc": 1.0, "parm": 5.0, "del_max": 15.0 },
  "rcs": { "mrcs_moment": 0, "mrcs_force": 0 },
  "control": {
    "maut": 60, "vac_rate_damp": 0.5, "vac_max_gain": 1.0,
    "tau_att": 1.0, "q_max": 15.0,
    "theta_com_inertial": 89.0, "psi_com_inertial": 90.0,
    "delimx": 15.0, "drlimx": 15.0,
    "gnmax": 5.0, "gymax": 5.0
  },
  "guidance": {
    "mguide": 2,
    "t_att_start": 3.0, "t_att_end": 15.0,
    "theta_com_start": 89.0, "theta_com_end": 70.0,
    "psi_com_start": 90.0,   "psi_com_end":   90.0
  },
  "ins":   { "mins": 1, "bias_accel": [0.001, 0, 0], "bias_gyro": [1.0e-5, 0, 0] },
  "gps":   { "mgps": 2, "gps_step": 1.0, "rpos": 5.0, "rvel": 0.1, "noise_seed": 12345 },
  "startrack": {
    "mstar": 2, "startrack_step": 1.0, "startrack_alt": 100000.0,
    "star_acqtime": 2.0, "tilt_noise": 1.0e-4
  },
  "intercept": {
    "check_alt_max": true, "check_time_max": true,
    "alt_max": 100000.0, "t_max": 25.0
  },
  "launch": {
    "lonx0": -80.0, "latx0": 28.5, "alt0": 0.0,
    "dvbe0": 0.01, "psivdx0": 90.0, "thtvdx0": 89.0,
    "psibdx0": 90.0, "thtbdx0": 89.0, "phibdx0": 0.0
  },
  "logger": { "sample_period": 0.1, "filename": "mission_log.csv" },
  "sim":    { "dt": 0.01, "t_max": 26.0 },

  // ---- Monte Carlo section ----
  "monte_carlo": {
    "seed":   42,
    "n_runs": 500,
    "variables": [
      // Propulsion: same as before
      { "path": "propulsion.fmass0",
        "distribution": "normal", "mean": 500.0, "stddev": 10.0 },
      { "path": "propulsion.spi",
        "distribution": "normal", "mean": 300.0, "stddev": 5.0 },
      { "path": "propulsion.fuel_flow_rate",
        "distribution": "normal", "mean": 20.0,  "stddev": 0.5 },

      // Launch attitude
      { "path": "launch.thtvdx0",
        "distribution": "uniform", "low": 88.5, "high": 89.5 },
      { "path": "launch.thtbdx0",
        "distribution": "uniform", "low": 88.5, "high": 89.5 },

      // INS sensor errors
      { "path": "ins.bias_accel[0]",
        "distribution": "lognormal", "mean": -7.0, "stddev": 0.3 },
      { "path": "ins.bias_gyro[0]",
        "distribution": "lognormal", "mean": -11.5, "stddev": 0.3 },

      // Sensor noise streams: pick a seed uniformly from 1..1e6
      { "path": "gps.noise_seed",
        "distribution": "uniform", "low": 1.0, "high": 1.0e6 },

      // Star tracker tilt noise scatter (lognormal around 1e-4 rad)
      { "path": "startrack.tilt_noise",
        "distribution": "lognormal", "mean": -9.2, "stddev": 0.3 }
    ],
    "outputs": [
      "t_end", "alt", "dvbi", "dvbe", "fpa", "theta", "psi",
      "ins_pos_err", "ins_vel_err", "ins_att_err",
      "delecx", "delrcx", "gps_updates"
    ]
  }
}
